# Name of the private S3 bucket that holds the source photos.
# Required to fetch the gallery; without it, the build produces an empty gallery.
PHOTOS_BUCKET_NAME=

# Region the photos bucket lives in.
AWS_REGION=us-east-1

# Base URL photos are served from. Defaults to the bucket's virtual-hosted
# S3 URL (https://<bucket>.s3.<region>.amazonaws.com). Override once a
# CloudFront distribution sits in front of the bucket.
PHOTOS_PUBLIC_URL_BASE=

# AWS credentials for scripts/fetch-photos.mjs to call s3:ListBucket / s3:GetObject.
# Leave unset locally to use your existing AWS CLI profile / SSO session
# (the AWS SDK picks that up automatically). In CI these come from the
# OIDC-assumed role instead — see .github/workflows/deploy.yml.
# AWS_PROFILE=
