# Name of the S3 bucket that hosts both the built site and the photos
# (photos live under the PHOTOS_PREFIX folder in the same bucket).
# Required to fetch albums; without it, the build produces an empty gallery.
BUCKET_NAME=

# Region the bucket lives in.
AWS_REGION=us-east-1

# Key prefix ("folder") photos live under. Each immediate subfolder is an
# album, e.g. photos/analog-camera/roll-01.jpg -> album "Analog Camera".
PHOTOS_PREFIX=photos/

# Base URL objects are served from. Defaults to the bucket's virtual-hosted
# S3 URL, but the bucket is private in this deployment (CloudFront + OAC
# only) — set this to your CloudFront domain or the raw S3 URL will 403.
PUBLIC_URL_BASE=https://xxxxxxxxxxxxxx.cloudfront.net

# AWS credentials for scripts/fetch-photos.mjs to call s3:ListBucket.
# Leave unset locally to use your existing AWS CLI profile / SSO session
# (the AWS SDK picks that up automatically). In CI these come from the
# OIDC-assumed role instead — see .github/workflows/deploy.yml.
# AWS_PROFILE=
