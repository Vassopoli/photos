---
import Layout from '../layouts/Layout.astro';
import photos from '../data/photos.json';
---

<Layout title="Vassopoli — Photography">
	<header class="site-header">
		<h1>Vassopoli</h1>
		<p>Photography portfolio</p>
	</header>

	{
		photos.length === 0 ? (
			<p class="empty">No photos yet.</p>
		) : (
			<div class="gallery">
				{photos.map((photo) => (
					<a class="tile" href={photo.url} target="_blank" rel="noreferrer">
						<img src={photo.url} alt="" loading="lazy" />
					</a>
				))}
			</div>
		)
	}
</Layout>

<style>
	.site-header {
		padding: 3rem 1.5rem 1.5rem;
		text-align: center;
	}

	.site-header h1 {
		margin: 0;
		font-size: 2rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.site-header p {
		margin: 0.25rem 0 0;
		color: var(--muted);
	}

	.empty {
		text-align: center;
		color: var(--muted);
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 4px;
		padding: 4px;
	}

	.tile {
		display: block;
		aspect-ratio: 1 / 1;
		overflow: hidden;
	}

	.tile img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease;
	}

	.tile:hover img {
		transform: scale(1.03);
	}
</style>
