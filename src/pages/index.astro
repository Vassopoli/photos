---
import Layout from '../layouts/Layout.astro';
import albums from '../data/albums.json';
---

<Layout title="Vassopoli — Photography">
	<header class="site-header">
		<h1>Vassopoli</h1>
		<p>Photography portfolio</p>
	</header>

	{
		albums.length === 0 ? (
			<p class="empty">No albums yet.</p>
		) : (
			<div class="albums">
				{albums.map((album) => (
					<a class="album-card" href={`/albums/${album.slug}/`}>
						<div class="cover">
							{album.photos[0] ? <img src={album.photos[0].url} alt="" loading="lazy" /> : <div class="cover-placeholder" />}
						</div>
						<h2>{album.title}</h2>
						<p>{album.photos.length} photo{album.photos.length === 1 ? '' : 's'}</p>
					</a>
				))}
			</div>
		)
	}
</Layout>

<style>
	.site-header {
		padding: 3rem 1.5rem 1.5rem;
		text-align: center;
	}

	.site-header h1 {
		margin: 0;
		font-size: 2rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.site-header p {
		margin: 0.25rem 0 0;
		color: var(--muted);
	}

	.empty {
		text-align: center;
		color: var(--muted);
	}

	.albums {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
		padding: 0 1.5rem 3rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	.album-card {
		color: inherit;
		text-decoration: none;
		display: block;
	}

	.cover {
		aspect-ratio: 4 / 3;
		overflow: hidden;
		border-radius: 4px;
		background: #1a1a1c;
	}

	.cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease;
	}

	.album-card:hover .cover img {
		transform: scale(1.03);
	}

	.cover-placeholder {
		width: 100%;
		height: 100%;
	}

	.album-card h2 {
		margin: 0.75rem 0 0;
		font-size: 1.1rem;
		font-weight: 500;
	}

	.album-card p {
		margin: 0.15rem 0 0;
		color: var(--muted);
		font-size: 0.9rem;
	}
</style>
